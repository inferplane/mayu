# inferplane environment variables — copy to .env (never commit .env).
# Secrets are referenced by config api_key_ref/token_refs, never inlined in config.json.

# Admin plane bearer token for the /admin/keys API
INFERPLANE_ADMIN_TOKEN=

# Upstream provider credentials (only those you enable)
ANTHROPIC_API_KEY=
VLLM_API_KEY=

# Amazon Bedrock: prefer IRSA on EKS (auth.mode: irsa). For local/profile auth,
# the AWS default credential chain is used (AWS_PROFILE / AWS_REGION / etc.).
# AWS_PROFILE=
# AWS_REGION=us-west-2

# Optional: Claude Code dev notification webhook (used by .claude/hooks/notify.sh)
# CLAUDE_NOTIFY_WEBHOOK=
